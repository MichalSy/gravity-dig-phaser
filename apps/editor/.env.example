# Client-visible URLs. These contain no secrets.
NEXT_PUBLIC_DEBUG_RELAY_URL=ws://localhost:8787/debug
NEXT_PUBLIC_GAME_URL=http://localhost:5173

# Server-only editor backend configuration.
EDITOR_GIT_REPO=https://github.com/MichalSy/gravity-dig-phaser.git
EDITOR_GIT_BRANCH=main
EDITOR_WORKSPACE=/tmp/gravity-dig-phaser-editor-workspace
EDITOR_ALLOWED_REPO_ROOTS=/tmp/gravity-dig-phaser-editor-workspace
EDITOR_UPLOAD_WORKSPACE=/tmp/gravity-dig-editor-uploads
EDITOR_GIT_AUTHOR_NAME="Gravity Dig Editor"
EDITOR_GIT_AUTHOR_EMAIL=editor@gravity-dig.local

# Required only when /api/editor/git/save/:sessionId needs to push.
GITHUB_TOKEN=
